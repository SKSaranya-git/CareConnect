# Used for `npm run build` / production (browser calls this host directly).
# During `npm run dev`, the app uses same-origin /api and Vite proxies to the gateway (see vite.config.js).
VITE_API_BASE_URL=http://localhost:8081

# Optional: where Vite should proxy /api in dev (default: http://localhost:8081)
# VITE_GATEWAY_PROXY_TARGET=http://localhost:8081
